# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors / OS
.idea/
.vscode/
.DS_Store

# Application data (runtime-generated)
captures/*
!captures/.gitkeep
logs/*
!logs/.gitkeep

# Downloaded model assets
*.task
*.tflite
*.onnx
gesturecam/models/*.task
